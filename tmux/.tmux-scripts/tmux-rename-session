#!/usr/bin/env bash

margin="--margin=40%,35%"
width=$(tput cols)
usable_width=$(( width * 30 / 100 ))
session="$1"
[ -z "$session" ] && exit 1

if echo "$session" | grep -qE '^[^a-zA-Z0-9] '; then
    session=$(echo "$session" | sed -E 's/^[^a-zA-Z0-9]* //')
fi

# Change to your colorscheme
bg="#1e1e2e"
bg_plus="#313244"
fg="#cdd6f4"
mauve="#cba6f7"
peach="#fab387"
overlay0="#6c7086"
header_red="#f38ba8"

wins=$(tmux list-windows -t "$session" 2>/dev/null | wc -l | tr -d ' ')
panes=$(tmux list-panes -t "$session" 2>/dev/null | wc -l | tr -d ' ')
path=$(tmux display-message -pt "$session" '#{pane_current_path}' 2>/dev/null)
path=$(basename "${path:-\.}")

content="󰓩 ${wins} • 󱂬 ${panes} • 󰉋 ${path}"
visual_width=$(echo -n "$content" | sed 's/[^ -~]/XX/g' | wc -c | tr -d ' ')
usable_width=$(( (width * 30 / 100) - 2 ))
padding=$(( (usable_width - visual_width) / 2 ))
[ $padding -lt 0 ] && padding=0
info=$(printf "%${padding}s%s" "" "$content")

error_msg=""
while true; do
  current_header="$overlay0"
  current_label="$mauve"
  current_border="$mauve"
  [ -n "$error_msg" ] && current_label="#f38ba8" && current_border="#f38ba8"

  input_result=$(fzf < /dev/null \
    --height=4 \
    --layout=reverse \
    --border=rounded \
    --border-label="${error_msg:-󰑕 RENAME SESSION}" \
    --border-label-pos=2 \
    --bind 'ctrl-e:abort' \
    --footer-label=" <Enter> Rename  <Esc> Cancel " \
    --footer-label-pos=center \
    --info=hidden \
    --no-separator \
    $margin \
    --padding=0 \
    --header="$info" \
    --color="bg:-1,bg+:$bg_plus,fg:$fg,fg+:$fg,border:$current_border,label:$current_label,header:$current_header,prompt:#7dc4e4,pointer:$fg,marker:$fg,spinner:$fg,info:#7dc4e4" \
    --prompt="󰊠  " \
    --query="$session" \
    --print-query | head -n1)

  exit_code=$?
  if [ $exit_code -ne 0 ] || [ -z "$input_result" ]; then
      exit 0
  fi

  new_name=$(echo "$input_result" | xargs)
  if [ "$new_name" = "$session" ] || [ -z "$new_name" ]; then
      exit 0
  fi

  if tmux has-session -t "$new_name" 2>/dev/null; then
    error_msg="󰚌 ERROR: SESSION '$new_name' ALREADY EXISTS"
    continue
  fi

  tmux rename-session -t "$session" "$new_name"
  exit 0
done