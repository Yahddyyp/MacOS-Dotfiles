#!/usr/bin/env bash

margin="--margin=40%,35%"
width=$(tput cols)
usable_width=$(( width * 30 / 100 ))
window_name="$1"
[ -z "$window_name" ] && window_name=$(tmux display-message -p '#W')

# Change to your colorscheme
bg="#1e1e2e"
bg_plus="#313244"
fg="#cdd6f4"
mauve="#cba6f7"
peach="#fab387"
overlay0="#6c7086"
sapphire="#7dc4e4"

index=$(tmux display-message -p '#I')
panes=$(tmux list-panes | wc -l | tr -d ' ')
command=$(tmux display-message -p '#{pane_current_command}')

content="󰖲 ${index} • 󱂬 ${panes} • 󰈚 ${command}"
# Calculate visual width (counting icons as 2 columns)
visual_width=$(echo -n "$content" | sed 's/[^ -~]/XX/g' | wc -c | tr -d ' ')
# Account for fzf's 30% width inside the 80% popup
usable_width=$(( (width * 30 / 100) - 2 ))
padding=$(( (usable_width - visual_width) / 2 ))
[ $padding -lt 0 ] && padding=0
info=$(printf "%${padding}s%s" "" "$content")

error_msg=""
while true; do
  # Set colors
  current_header="$overlay0"
  current_label="$mauve"
  current_border="$mauve"
  [ -n "$error_msg" ] && current_label="#f38ba8" && current_border="#f38ba8"

  input_result=$(fzf < /dev/null \
    --height=4 \
    --layout=reverse \
    --border=rounded \
    --border-label="${error_msg:-󰑕 RENAME WINDOW}" \
    --border-label-pos=2 \
    --footer-label=" <Enter> Rename  <Esc> Cancel " \
    --footer-label-pos=center \
    --info=hidden \
    --no-separator \
    $margin \
    --padding=0 \
    --header="$info" \
    --color="bg:-1,bg+:$bg_plus,fg:$fg,fg+:$fg,border:$current_border,label:$current_label,header:$current_header,prompt:$sapphire,pointer:$fg,marker:$fg,spinner:$fg,info:$sapphire" \
    --prompt="󰊠  " \
    --query="$window_name" \
    --print-query | head -n1)

  exit_code=$?
  if [ $exit_code -ne 0 ] || [ -z "$input_result" ]; then
      exit 0
  fi

  new_name=$(echo "$input_result" | xargs)
  if [ "$new_name" = "$window_name" ] || [ -z "$new_name" ]; then
      exit 0
  fi

  # Check if window name already exists in current session
  if tmux list-windows -F '#W' | grep -q "^$new_name$"; then
    error_msg="󰚌 ERROR: WINDOW '$new_name' ALREADY EXISTS"
    continue
  fi

  tmux rename-window "$new_name"
  exit 0
done
