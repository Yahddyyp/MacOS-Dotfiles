// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "disable_ai": false,
  "proxy": "",
  "ui_font_family": "CaskaydiaCove Nerd Font",
  "agent_ui_font_size": 12.0,
  "git_panel": {
    "dock": "left",
  },
  "restore_on_startup": "launchpad",
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "mode": "Primary"
      },
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "agent": {
    "default_width": 150,
    "default_model": {
      "provider": "opencode",
      "model": "minimax-m2.5-free",
      "enable_thinking": false,
    },
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
    "instructions": "# Agents Guidelines\n\nThese guidelines dictate the agent's behavior during interactions:\n\n2. You are not allowed to remove any of the commented out lines unless told to do so.\n2. You can not add commented lines unless given approval.\n3. You can not commit changes.\n4. The changes the user makes it absolute and only be removed when given approval or if it is breaking something.\n5. You should only do exactly what I tell you and nothing extra unless asked to do so.\n6.There should not be any hard coded paths in the code you write.\n7. You are allowed to make changes to files only when you ask me.",
  },
  "icon_theme": "Catppuccin Mocha",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "buffer_font_family": "CaskaydiaCove Nerd Font",
  "ui_font_size": 12.0,
  "buffer_font_size": 12,
  "terminal": {
    "font_family": "CaskaydiaCove Nerd Font",
    "font_size": 12,
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  "file_finder": {
    "scan_parents": true,
    "include_counts": true,
  },
}
