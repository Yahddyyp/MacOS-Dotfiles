[
  {
    "context": "Workspace",
    "bindings": {
      "tab": "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePreviousItem",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-e": "workspace::NewFile",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "jj": "vim::NormalBefore",
      "space w": "workspace::Save",
      "space q": "pane::CloseActiveItem",
      "space f": "file_finder::Toggle",
      "space r n": "editor::Rename",
      "space e": "project_panel::Toggle",
      "space h": "zed::ShowWelcome",
      "space c": "buffer_search::Dismiss",
      "space p": "workspace::ToggleRightDock",
      "space o c": "agent::Toggle",
      "space m": "pane::SplitVertical",
      "space u": "pane::SplitHorizontal",
      "space b d": "pane::CloseActiveItem",
      "space x": "pane::CloseActiveItem",
      "space Tab": "pane::ActivateLastItem",
      "ctrl-/": "terminal_panel::Toggle",
      "space t": "debug_panel::Toggle",
      "space g g": "git_panel::Toggle",
      "Tab": "pane::ActivateNextItem",
      "shift-Tab": "pane::ActivatePreviousItem",
    },
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      "space space": "file_finder::Toggle",
      "U": "editor::Redo",
      "ctrl-a": "vim::FirstNonWhitespace",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "ctrl-d": "vim::EndOfLine",
    },
  },

  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j j": "vim::NormalBefore",
      "j k": "vim::NormalBefore",
    },
  },
]
