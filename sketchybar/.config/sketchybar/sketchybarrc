#!/usr/bin/env lua

-- Add the config directory to Lua's module search path
local config_dir = os.getenv("HOME") .. "/.config/sketchybar"
package.path = package.path .. ";" .. config_dir .. "/?.lua;" .. config_dir .. "/?/init.lua"

-- Add the sketchybar module to the package cpath
package.cpath = package.cpath .. ";"
             .. os.getenv("HOME") .. "/.local/share/sketchybar_lua/?.so"

-- Require the sketchybar module
sbar = require("sketchybar")

-- Bundle the entire initial configuration into a single IPC message
sbar.begin_config()
require("init")
sbar.hotload(true)
sbar.end_config()

-- Run the event loop (required for callbacks)
sbar.event_loop()
