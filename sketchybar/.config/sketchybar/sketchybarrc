sketchybar --add item space_watcher center \
           --set space_watcher background.drawing=off \
                                 script="$PLUGIN_DIR/space_windows.sh" \
           --subscribe space_watcher space_windows_change window_focus space_change

sketchybar --add item front_app left \
           --set front_app icon.font="sketchybar-app-font:Regular:18.0" \
                           icon.color=0xffcba6f7 \
                           label.color=0xffcdd6f4 \
                           background.color=0xcc313244 \
                           background.border_color=0x88cba6f7 \
                           background.border_width=1 \
                           script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

yabai -m signal --add event=window_focused action="sketchybar --trigger window_focus"
yabai -m signal --add event=space_changed action="sketchybar --trigger space_change"
yabai -m signal --add event=window_created action="sketchybar --trigger window_focus"
yabai -m signal --add event=window_destroyed action="sketchybar --trigger space_windows_change"

sketchybar --update

